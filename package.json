{
  "name": "superposition",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "generate-routes": "tsr generate",
    "build": "bun run paraglide && tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "test": "vitest run",
    "verify": "bun src/solver/verify.ts",
    "gen": "bun src/solver/generate.ts",
    "gen:hero": "bun scripts/gen-hero.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@inlang/paraglide-js": "^2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@tanstack/router-cli": "^1.132.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
