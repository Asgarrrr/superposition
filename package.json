{
  "name": "superposition",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "generate-routes": "tsr generate",
    "build": "bun run paraglide && tsc --noEmit && vite build",
    "start": "bun .output/server/index.mjs",
    "preview": "vite preview",
    "lint": "oxlint",
    "test": "vitest run",
    "verify": "bun src/solver/verify.ts",
    "gen": "bun src/solver/generate.ts",
    "gen:daily": "bun src/solver/generate-daily.ts",
    "gen:hero": "bun scripts/gen-hero.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "auth:generate": "bunx @better-auth/cli@latest generate --config src/lib/auth.ts --output src/db/schema.ts -y"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "motion": "^12.42.2",
    "pg": "8.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@inlang/paraglide-js": "^2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/router-cli": "^1.132.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.10.2",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "0.31.10",
    "nitro": "^3.0.260610-beta",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
