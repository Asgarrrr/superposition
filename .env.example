# Server-only secrets. NEVER prefix with VITE_ (that would inline them into the
# browser bundle). Copy to .env for local dev; Railway injects the real values.

# Postgres connection. Local dev uses docker-compose.yml; on Railway set this to
# ${{Postgres.DATABASE_URL}} (private host, no SSL needed).
DATABASE_URL=postgres://superposition:superposition@localhost:5432/superposition

# Better Auth. Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-me-please-0000000000000000
# Public origin of the app. Local dev on :3000; on Railway use the public domain.
BETTER_AUTH_URL=http://localhost:3000
